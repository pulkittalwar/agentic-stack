{
  "name": "claude-code",
  "description": "Claude Code (Anthropic) — CLAUDE.md instructions + .claude/settings.json PostToolUse + Stop hooks. Hook commands use $CLAUDE_PROJECT_DIR for cwd-stable resolution (closes #18).",
  "brain_root_primitive": "$CLAUDE_PROJECT_DIR",
  "files": [
    {
      "src": "CLAUDE.md",
      "dst": "CLAUDE.md",
      "merge_policy": "overwrite"
    },
    {
      "src": "settings.json",
      "dst": ".claude/settings.json",
      "merge_policy": "overwrite",
      "substitute": true
    },
    {
      "src": "agents/architect.md",
      "dst": ".claude/agents/architect.md",
      "merge_policy": "overwrite"
    },
    {
      "src": "agents/engineer.md",
      "dst": ".claude/agents/engineer.md",
      "merge_policy": "overwrite"
    },
    {
      "src": "agents/product-manager.md",
      "dst": ".claude/agents/product-manager.md",
      "merge_policy": "overwrite"
    },
    {
      "src": "agents/release-manager.md",
      "dst": ".claude/agents/release-manager.md",
      "merge_policy": "overwrite"
    },
    {
      "src": "agents/reviewer.md",
      "dst": ".claude/agents/reviewer.md",
      "merge_policy": "overwrite"
    }
  ]
}
