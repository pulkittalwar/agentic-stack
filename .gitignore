# env and secrets
.env
.env.local
*.key

# python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# tests live outside the repo — keep in your local working tree but don't
# ship them in releases or the brew bottle.
tests/

# editor
.DS_Store
.idea/
*.swp

# runtime logs
.agent/memory/dream.log
*.log

# local agent activity/data-layer exports (private, regenerated)
.agent/data-layer/
.agent/data-layer/**

# do NOT ignore memory files — they are the point
!.agent/memory/
!.agent/memory/**

# ...EXCEPT the derived search index (auto-rebuilt, per-machine).
# Placed AFTER the negation above so the later rule wins.
.agent/memory/.index/
.agent/memory/.index/**
