{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-stack.dev/schemas/flywheel/eval-case.schema.json",
  "title": "EvalCase",
  "description": "Holdout eval case created from a redacted human-approved workflow run.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "domain", "workflow", "input_redacted", "expected_behavior", "forbidden_behavior", "rubric", "tags", "source_trace_ids"],
  "properties": {
    "id": {"type": "string"},
    "domain": {"type": "string"},
    "workflow": {"type": "string"},
    "input_redacted": {"type": "string"},
    "expected_behavior": {"type": "array", "items": {"type": "string"}},
    "forbidden_behavior": {"type": "array", "items": {"type": "string"}},
    "rubric": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "source_trace_ids": {"type": "array", "items": {"type": "string"}}
  }
}
