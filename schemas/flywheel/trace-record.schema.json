{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-stack.dev/schemas/flywheel/trace-record.schema.json",
  "title": "TraceRecord",
  "description": "Redacted approved-run trace for retrieval, evals, prompt shrinking, or later training candidates.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "created_at", "project", "domain", "workflow", "host", "input_hash", "raw_input_stored", "pii_level", "redaction_status", "human_review", "trainable", "target_use"],
  "properties": {
    "id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "project": {"type": "string"},
    "domain": {"type": "string"},
    "workflow": {"type": "string"},
    "skill": {"type": "string"},
    "host": {"type": "string"},
    "model_used": {"type": "string"},
    "input_summary": {"type": "string"},
    "input_hash": {"type": "string"},
    "raw_input_stored": {"type": "boolean", "const": false},
    "pii_level": {"type": "string"},
    "redaction_status": {"type": "string"},
    "context_tokens_before": {"type": ["number", "null"], "minimum": 0},
    "context_tokens_after": {"type": ["number", "null"], "minimum": 0},
    "output_summary": {"type": "string"},
    "human_review": {"type": "object", "additionalProperties": true},
    "eval_tags": {"type": "array", "items": {"type": "string"}},
    "failure_modes": {"type": "array", "items": {"type": "string"}},
    "trainable": {"type": "boolean"},
    "target_use": {"type": "array", "items": {"type": "string"}},
    "model_target": {"type": "object", "additionalProperties": true},
    "source_run_id_hash": {"type": "string"}
  }
}
