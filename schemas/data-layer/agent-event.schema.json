{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-stack.dev/schemas/data-layer/agent-event.schema.json",
  "title": "AgentEvent",
  "description": "Normalized local agent activity across agentic-stack harnesses.",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "created_at", "project", "harness", "skill", "workflow", "phase", "status", "privacy_level", "pii_level"],
  "properties": {
    "id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": ["string", "null"], "format": "date-time"},
    "project": {"type": "string"},
    "harness": {"type": "string", "examples": ["claude-code", "hermes", "openclaw", "codex", "cursor", "opencode"]},
    "skill": {"type": "string"},
    "action": {"type": "string"},
    "workflow": {"type": "string"},
    "phase": {"type": "string", "examples": ["plan", "review", "qa", "ship", "debug", "memory", "analysis"]},
    "run_type": {"type": "string", "examples": ["agent", "manual", "hook"]},
    "category": {"type": "string", "examples": ["personal", "admin", "work", "financial", "coding"]},
    "result": {"type": "string"},
    "status": {"type": "string", "examples": ["success", "error", "unknown"]},
    "duration_ms": {"type": ["integer", "null"], "minimum": 0},
    "tokens_in_estimate": {"type": ["number", "null"], "minimum": 0},
    "tokens_out_estimate": {"type": ["number", "null"], "minimum": 0},
    "tokens_total_estimate": {"type": ["number", "null"], "minimum": 0},
    "cost_estimate_usd": {"type": ["number", "null"], "minimum": 0},
    "agent_id_hash": {"type": ["string", "null"]},
    "profile_hash": {"type": ["string", "null"]},
    "run_id_hash": {"type": ["string", "null"]},
    "privacy_level": {"type": "string", "examples": ["local_only", "sanitized_export"]},
    "pii_level": {"type": "string", "examples": ["none", "low", "medium", "high", "unknown"]}
  }
}
